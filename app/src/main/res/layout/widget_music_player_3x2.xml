<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_gradient">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="10dp">

        <!-- ===== Top half: big cover art ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/widget_cover"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:scaleType="centerCrop"
                android:background="@drawable/widget_cover_rounded"
                android:clipToOutline="true" />
        </LinearLayout>

        <!-- ===== Bottom half: info + controls ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginTop="8dp">

            <!-- Song info -->
            <TextView
                android:id="@+id/widget_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MOTO Music"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:shadowColor="#B0000000"
                android:shadowRadius="4" />

            <TextView
                android:id="@+id/widget_artist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#BFFFFFFF"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="2dp"
                android:shadowColor="#B0000000"
                android:shadowRadius="3" />

            <!-- Controls row -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="6dp">

                <ImageView
                    android:id="@+id/widget_btn_prev"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:src="@drawable/ic_prev"
                    android:padding="6dp"
                    android:alpha="0.85"
                    android:contentDescription="Previous" />

                <ImageView
                    android:id="@+id/widget_btn_play_pause"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_play"
                    android:padding="8dp"
                    android:alpha="0.95"
                    android:layout_marginHorizontal="12dp"
                    android:contentDescription="Play/Pause" />

                <ImageView
                    android:id="@+id/widget_btn_next"
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:src="@drawable/ic_next"
                    android:padding="6dp"
                    android:alpha="0.85"
                    android:contentDescription="Next" />

            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>