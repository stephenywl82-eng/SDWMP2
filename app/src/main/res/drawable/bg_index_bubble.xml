<?xml version="1.0" encoding="utf-8"?>
<!-- 【v2.0】字母索引气泡背景 -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">
    
    <!-- 半透明深色背景 -->
    <solid android:color="#E61A1A1F" />
    
    <!-- 白色描边 -->
    <stroke
        android:width="1dp"
        android:color="#33D4B8F0" />
    
    <!-- 内边距 -->
    <padding
        android:left="8dp"
        android:top="8dp"
        android:right="8dp"
        android:bottom="8dp" />
</shape>
